{
  "neo4j": {
    "NEO4J_server_memory_heap_initial__size": "512m",
    "NEO4J_server_memory_heap_max__size": "2G",
    "NEO4J_server_memory_pagecache_size": "512m"
  },
  "vast": {
    "MLIR_LEVEL": "hl",
    "LLVM_COMPILER": "clang",
    "MLIR_COMPILER_PATH": "/path/to/vast/builds/default/tools/vast-front/Release",
    "MLIR_FLAGS": "-fno-crash-diagnostics -vast-test-db",
    "WLLVM_TIMEOUT_SECS": 7200
  },
  "neo4j_image": "neo4j:latest"
}
